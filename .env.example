# ==============================================================================
# MiGallery - Configuration de l'environnement
# ==============================================================================
# Copier ce fichier en .env et remplir les valeurs manquantes.
# Ne jamais committer le fichier .env !
# Pour la production : stocker les secrets sur le serveur dans ~/MiGallery/.env
# Pour la CI GitHub : utiliser les GitHub Repository Secrets si nécessaire.
# ==============================================================================

# --- Immich (galerie de photos) -----------------------------------------------
IMMICH_BASE_URL=http://10.0.0.4:2283
IMMICH_API_KEY=votre_clé_api_immich

# --- Authentik MiConnect (OIDC - SSO) ----------------------------------------
# L'issuer est visible dans : Authentik > Applications > MiGallery > Aperçu OpenId
MICONNECT_ISSUER=https://auth.canari-emse.fr/application/o/migallery/
# Client ID et Secret générés dans Authentik > Fournisseurs > MiGallery
MICONNECT_CLIENT_ID=votre_client_id
MICONNECT_CLIENT_SECRET=votre_client_secret
# Callback URL à déclarer dans Authentik : https://gallery.mitv.fr/auth/callback/miconnect

# --- Auth.js ------------------------------------------------------------------
# Générer avec : node ./scripts/generate-auth-secret.cjs
AUTH_SECRET=générer_une_clé_aléatoire_forte
AUTH_TRUSTED_HOST=true

# --- Serveur ------------------------------------------------------------------
PORT=3000
ORIGIN=https://gallery.mitv.fr
DATABASE_PATH=./data/migallery.db

# --- Sécurité cookies ---------------------------------------------------------
# Générer avec : node ./scripts/generate_cookie_secret.cjs
COOKIE_SECRET=générer_une_clé_aléatoire_forte

# --- Upload -------------------------------------------------------------------
BODY_SIZE_LIMIT=20G

# --- Dev routes (ne jamais activer en production) -----------------------------
ENABLE_DEV_ROUTES=false
