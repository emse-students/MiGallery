{
	"name": "migallery",
	"private": true,
	"version": "1.1.0",
	"description": "MiGallery, by MiTV",
	"type": "module",
	"author": "DeMASKe",
	"license": "SEE LICENSE IN LICENSE",
	"repository": {
		"type": "git",
		"url": "https://github.com/emse-students/MiGallery.git"
	},
	"homepage": "https://github.com/emse-students/MiGallery#readme",
	"keywords": [
		"sveltekit",
		"svelte",
		"vite",
		"node",
		"gallery"
	],
	"files": [
		"build/",
		"src/",
		"README.md"
	],
	"engines": {
		"node": ">=20.0.0"
	},
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "husky",
		"paraglide:compile": "paraglide-js compile --project ./project.inlang --outdir ./src/lib/paraglide",
		"check": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "npm run paraglide:compile && svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint src/lib --ext .ts,.tsx,.js,.jsx --cache && eslint src/routes --ext .ts,.tsx,.js,.jsx --cache",
		"lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --ignore-pattern 'scripts/**' --fix",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"deps:install": "npm install",
		"ci:install": "npm ci",
		"ci:build": "npm ci && npm run build",
		"start": "node build/index.js",
		"package": "npm run build && node -e \"require('fs').mkdirSync('build/artifacts',{ recursive: true })\" && npm pack --pack-destination build/artifacts",
		"version:show": "node -e \"console.log(require('./package.json').version)\"",
		"db:init": "node ./scripts/init-db.cjs",
		"db:backup": "node ./scripts/backup-db.cjs",
		"db:inspect": "node ./scripts/inspect-db.cjs",
		"immich:cleanup-test-albums": "node ./scripts/cleanup-immich-test-albums.mjs",
		"test:cleanup": "node ./scripts/cleanup-test-artifacts.cjs",
		"validate": "node scripts/ci-local.mjs",
		"test": "node scripts/test-with-server.mjs",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:unit": "vitest run",
		"test:albums": "vitest run tests/albums.test.ts",
		"test:users": "vitest run tests/users.test.ts",
		"test:admin": "vitest run tests/admin-auth.test.ts",
		"test:people": "vitest run tests/people-photoscv.test.ts",
		"test:immich": "vitest run tests/immich-proxy.test.ts",
		"test:favorites": "vitest run tests/favorites-external.test.ts",
		"test:e2e": "vitest run tests/e2e-integration.test.ts",
		"generate:secret": "node ./scripts/generate_cookie_secret.cjs",
		"generate:auth-secret": "node ./scripts/generate-auth-secret.cjs",
		"cleanup:chunked-temp": "node ./scripts/cleanup-chunked-temp.js",
		"db:reset-users": "node ./scripts/reset-users-for-authentik.cjs"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.22.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-node": "^5.5.7",
		"@sveltejs/kit": "^2.69.3",
		"@sveltejs/vite-plugin-svelte": "^7.2.0",
		"@tailwindcss/postcss": "^4.3.2",
		"@types/better-sqlite3": "^7.6.13",
		"@types/form-data": "^2.5.2",
		"@typescript-eslint/eslint-plugin": "^8.64.0",
		"@typescript-eslint/parser": "^8.58.0",
		"@vitest/coverage-v8": "^4.1.10",
		"autoprefixer": "^10.5.3",
		"eslint": "^10.7.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.20.0",
		"husky": "^9.1.7",
		"lint-staged": "^17.0.8",
		"postcss": "^8.5.13",
		"prettier": "^3.9.5",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.5",
		"svelte-check": "^4.7.2",
		"svelte-eslint-parser": "^1.6.0",
		"tailwindcss": "^4.3.1",
		"tar": "^7.5.20",
		"typescript": "~6.0.3",
		"vite": "^8.1.4"
	},
	"dependencies": {
		"@eslint/js": "^10.0.1",
		"better-sqlite3": "^12.9.0",
		"dotenv": "^17.4.2",
		"form-data": "^4.0.5",
		"jspdf": "^4.2.1",
		"jspdf-autotable": "^5.0.7",
		"lucide-svelte": "^1.0.1",
		"sharp": "^0.34.5",
		"typescript-eslint": "^8.61.1",
		"undici": "^8.0.3",
		"vitest": "^4.0.10"
	},
	"overrides": {
		"cookie": "^0.7.0"
	},
	"lint-staged": {
		"*.{js,ts,jsx,tsx,svelte}": [
			"eslint --fix",
			"prettier --write --ignore-unknown"
		],
		"*.{json,md,yml,yaml,css,html}": [
			"prettier --write --ignore-unknown"
		]
	}
}
